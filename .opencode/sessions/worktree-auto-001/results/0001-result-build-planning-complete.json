  "key_decisions": {
    "architecture": "Hybrid: Custom tool (worktree creation) + Plugin hook (auto-session)",
    "rationale": "Custom tools are 100% reliable in Desktop; plugins have SDK access but load inconsistently. Hybrid provides best of both with graceful fallback.",
    "key_learnings": [
      "ToolContext does not have '$' - must use Bun.$ directly",
      "Return structured JSON from tools for hooks to parse",
      "Named exports required for plugins (export const Name)",
      "Hook tool.execute.after triggers after tool succeeds"
    ]
  },
  "workflow_specifications": {
    "tool_return_format": {
      "type": "structured_json",
      "fields": ["status", "worktreePath", "branchName", "issue", "baseBranch", "baseCommit", "fallback", "error"],
      "example": "{\"status\":\"success\",\"worktreePath\":\"/path\",\"branchName\":\"fix/bug-123\",...}"
    },
    "hook_trigger": {
      "event": "tool.execute.after",
      "condition": "input.tool === 'worktree-prepare'",
      "parse": "JSON.parse(output.result)",
      "validation": "result.status === 'success'"
    },
    "sdk_calls": [
      "context.client.session.create({ query: { directory }, body: { parentID, title } })",
      "context.client.session.prompt({ path: { id }, body: { parts: [issueContext] } })"
    ]
  },
